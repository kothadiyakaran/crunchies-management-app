coverage/
*.lcov
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local

# Supabase
.supabase/
supabase/.temp/

# Editor / IDE
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS
*.tmp
*.temp

# Claude Code project-local (machine-specific, not shared)
.claude/settings.local.json
.claude/.cache/

# Skills install: .claude/skills/ are absolute-path symlinks into .agents/skills/.
# Track .agents/skills/ (the real content) instead — symlinks are regenerated
# per machine by `npx skills add` (or the install command).
.claude/skills/

# Playwright
test-results/
playwright-report/
playwright/.cache/

# Local smoke-test outputs (the scripts are tracked, the captures aren't)
scripts/screenshots/

# Python bytecode cache (smoke scripts are run, not packaged)
__pycache__/
*.pyc

# TypeScript
*.tsbuildinfo

# Misc
.cache/
